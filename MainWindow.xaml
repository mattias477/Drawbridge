<Window x:Class="Drawbridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drawbridge" Height="600" Width="880"
        Background="#1E2430">

    <Window.Resources>
        <!-- Sidebar navigation item -->
        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#AAB3C5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                Padding="12,10" Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1E2430"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#252C3B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buttons -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#3B82F6"/>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#6B7280"/>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#10B981"/>
        </Style>

        <!-- Cards & text -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#252C3B"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="TabTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A93A6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAB3C5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D5DCE8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#141922"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3B4252"/>
            <Setter Property="Padding" Value="7,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DarkPin" TargetType="PasswordBox">
            <Setter Property="Background" Value="#141922"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3B4252"/>
            <Setter Property="Padding" Value="7,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ==================== MAIN CONTENT ==================== -->
        <Grid x:Name="MainContent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Sidebar ===== -->
            <Border Grid.Column="0" Background="#161B26">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <StackPanel Orientation="Horizontal" Margin="16,18,0,20">
                            <TextBlock Text="🏰" FontSize="22" VerticalAlignment="Center"/>
                            <TextBlock Text="Drawbridge" FontSize="18" FontWeight="Bold"
                                       Foreground="White" Margin="8,0,8,0"
                                       VerticalAlignment="Center"/>
                            <Ellipse x:Name="SideStatusLight" Width="9" Height="9"
                                     Fill="IndianRed" VerticalAlignment="Center"/>
                        </StackPanel>

                        <RadioButton Style="{StaticResource NavItem}" Tag="Dashboard"
                                     Content="🏠  Dashboard" IsChecked="True"
                                     Checked="Nav_Checked"/>
                        <RadioButton Style="{StaticResource NavItem}" Tag="Blocklists"
                                     Content="📋  Blocklists" Checked="Nav_Checked"/>
                        <RadioButton Style="{StaticResource NavItem}" Tag="Settings"
                                     Content="⚙️  Settings" Checked="Nav_Checked"/>
                        <RadioButton Style="{StaticResource NavItem}" Tag="Security"
                                     Content="🔒  Security" Checked="Nav_Checked"/>
                        <RadioButton Style="{StaticResource NavItem}" Tag="Logs"
                                     Content="📜  Logs" Checked="Nav_Checked"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,14"
                                VerticalAlignment="Bottom">
                        <Button x:Name="LockNowButton" Content="🔒 Lock now"
                                Style="{StaticResource SecondaryButton}"
                                Visibility="Collapsed" Margin="0,0,0,10"
                                Click="LockNowButton_Click"/>
                        <TextBlock Text="Drawbridge v0.6" Style="{StaticResource Hint}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Grid/>
                </DockPanel>
            </Border>

            <!-- ===== Content area ===== -->
            <Grid Grid.Column="1" Margin="24,20,24,20">

                <!-- ========== DASHBOARD ========== -->
                <Grid x:Name="TabDashboard">
                    <StackPanel>
                        <TextBlock Text="Dashboard" Style="{StaticResource TabTitle}"/>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <Ellipse x:Name="StatusLight" Width="16" Height="16"
                                             Fill="IndianRed" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusText" FontSize="17"
                                               Text="Bridge is down (not filtering)"
                                               Foreground="White" Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="ToggleButton" Content="Raise the Bridge (Start)"
                                        Style="{StaticResource PrimaryButton}" FontSize="15"
                                        HorizontalAlignment="Left"
                                        Click="ToggleButton_Click"/>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock x:Name="DomainsLoadedText" Text="0" FontSize="30"
                                               FontWeight="Bold" Foreground="#3B82F6"/>
                                    <TextBlock Text="domains on the blocklist"
                                               Style="{StaticResource Hint}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock x:Name="SessionBlockedText" Text="0" FontSize="30"
                                               FontWeight="Bold" Foreground="#EF4444"/>
                                    <TextBlock Text="lookups blocked this session"
                                               Style="{StaticResource Hint}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- ========== BLOCKLISTS ========== -->
                <Grid x:Name="TabBlocklists" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Blocklists" Style="{StaticResource TabTitle}"/>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="Sources" FontSize="15" FontWeight="SemiBold"
                                               Foreground="White" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="BlockedCountText" Text="0 domains loaded"
                                               Foreground="#AAB3C5" HorizontalAlignment="Right"/>
                                </DockPanel>

                                <ListBox x:Name="BlocklistUrls" Height="140" Background="#141922"
                                         Foreground="#D5DCE8" BorderThickness="0" FontSize="12"
                                         Padding="4"/>

                                <TextBlock Text="Add a new list URL (Adblock format)"
                                           Style="{StaticResource FieldLabel}" Margin="0,12,0,3"/>
                                <DockPanel>
                                    <Button x:Name="RemoveUrlButton" Content="Remove selected"
                                            Style="{StaticResource SecondaryButton}"
                                            DockPanel.Dock="Right" Margin="8,0,0,0"
                                            Click="RemoveUrlButton_Click"/>
                                    <Button x:Name="AddUrlButton" Content="Add list"
                                            Style="{StaticResource PrimaryButton}"
                                            DockPanel.Dock="Right" Margin="8,0,0,0"
                                            Click="AddUrlButton_Click"/>
                                    <TextBox x:Name="NewUrlBox" Style="{StaticResource DarkInput}"/>
                                </DockPanel>

                                <Button x:Name="CheckUpdatesButton" Content="⟳ Check for updates"
                                        Style="{StaticResource SuccessButton}"
                                        HorizontalAlignment="Left" Margin="0,12,0,0"
                                        Click="CheckUpdatesButton_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ========== SETTINGS ========== -->
                <Grid x:Name="TabSettings" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Settings" Style="{StaticResource TabTitle}"/>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Protect this computer" FontSize="15"
                                           FontWeight="SemiBold" Foreground="White"
                                           Margin="0,0,0,10"/>

                                <CheckBox x:Name="SystemDnsCheck" Style="{StaticResource DarkCheck}"
                                          Content="Route this computer's DNS through Drawbridge"
                                          Checked="SystemDnsCheck_Changed"
                                          Unchecked="SystemDnsCheck_Changed"/>

                                <CheckBox x:Name="RunAtLoginCheck" Style="{StaticResource DarkCheck}"
                                          Content="Start Drawbridge automatically at login"
                                          Checked="RunAtLoginCheck_Changed"
                                          Unchecked="RunAtLoginCheck_Changed"/>

                                <TextBlock Style="{StaticResource Hint}"
                                           Text="With both boxes checked, filtering is always on. Note: while DNS is routed through Drawbridge, the internet only works when the bridge is up — that's the protection working."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ========== SECURITY ========== -->
                <Grid x:Name="TabSecurity" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Security" Style="{StaticResource TabTitle}"/>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock x:Name="PinPanelTitle" Text="PIN lock" FontSize="15"
                                           FontWeight="SemiBold" Foreground="White"
                                           Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" x:Name="CurrentPinPanel"
                                                Visibility="Collapsed">
                                        <TextBlock Text="Current PIN"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <PasswordBox x:Name="CurrentPinBox"
                                                     Style="{StaticResource DarkPin}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="New PIN (min 4 digits)"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <PasswordBox x:Name="NewPinBox"
                                                     Style="{StaticResource DarkPin}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Confirm new PIN"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <PasswordBox x:Name="ConfirmPinBox"
                                                     Style="{StaticResource DarkPin}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button x:Name="SetPinButton" Content="Set PIN &amp; lock"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="SetPinButton_Click"/>
                                    <Button x:Name="RemovePinButton" Content="Remove PIN"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="8,0,0,0" Visibility="Collapsed"
                                            Click="RemovePinButton_Click"/>
                                </StackPanel>

                                <TextBlock Style="{StaticResource Hint}" Margin="0,12,0,0"
                                           Text="Once a PIN is set, Drawbridge starts locked: only the unlock screen is visible, and the app can't be closed without the PIN. Filtering always stays active while locked."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ========== LOGS ========== -->
                <Grid x:Name="TabLogs" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Logs" Style="{StaticResource TabTitle}"/>

                    <Border Grid.Row="1" Background="#141922" CornerRadius="8" Padding="8">
                        <ListBox x:Name="LogList" Background="Transparent" BorderThickness="0"
                                 Foreground="#9FE8A5" FontFamily="Consolas" FontSize="12"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ==================== LOCK SCREEN OVERLAY ==================== -->
        <Grid x:Name="LockOverlay" Background="#1E2430" Visibility="Collapsed"
              Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
                <TextBlock Text="🔒" FontSize="52" HorizontalAlignment="Center"/>
                <TextBlock Text="Drawbridge is locked" FontSize="20" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,2"/>
                <TextBlock Text="Filtering is still active." FontSize="12"
                           Foreground="#8A93A6" HorizontalAlignment="Center" Margin="0,0,0,18"/>

                <PasswordBox x:Name="UnlockPinBox" FontSize="18" Padding="8,6"
                             Background="#141922" Foreground="White" BorderBrush="#3B4252"
                             HorizontalContentAlignment="Center"
                             KeyDown="UnlockPinBox_KeyDown"/>

                <Button x:Name="UnlockButton" Content="Unlock" FontSize="15"
                        Style="{StaticResource PrimaryButton}" Margin="0,10,0,0"
                        Click="UnlockButton_Click"/>

                <TextBlock x:Name="UnlockError" Foreground="IndianRed" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,10,0,0" Text=""/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
